import { VerticalBox, HorizontalBox } from "std-widgets.slint";

component MetricCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <length> value-size: 24px;

    border-radius: 12px;
    background: #1e293b;
    height: 88px;
    min-width: 0px;

    VerticalBox {
        padding: 12px;
        spacing: 7px;

        Text {
            text: root.label;
            color: #94a3b8;
            font-size: 12px;
            overflow: elide;
        }

        Text {
            text: root.value;
            color: #f8fafc;
            font-size: root.value-size;
            font-weight: 700;
            overflow: elide;
        }
    }
}

component SectionCard inherits Rectangle {
    border-radius: 14px;
    background: #1e293b;
}

export component MainWindow inherits Window {
    title: "Hotspot Hub";
    preferred-width: 392px;
    preferred-height: 780px;
    default-font-family: "Noto Sans CJK SC";
    background: #0f172a;

    in property <string> status: "未知";
    in property <string> status-reason: "等待采样";
    in property <string> elapsed: "0 分钟";
    in property <string> session-traffic: "--";
    in property <string> down-speed: "--";
    in property <string> up-speed: "--";
    in property <string> connected-count: "系统限制";
    in property <string> battery: "--";
    in property <string> temperature: "--";
    in property <string> last-updated: "等待第一次采样";

    Rectangle {
        width: min(parent.width - 32px, 368px);
        height: parent.height;
        x: (parent.width - self.width) / 2;
        background: transparent;

        VerticalBox {
            padding-top: 18px;
            padding-bottom: 18px;
            spacing: 12px;

            HorizontalBox {
                spacing: 12px;
                height: 66px;

                VerticalBox {
                    spacing: 3px;
                    Text {
                        text: "热点中枢";
                        color: #94a3b8;
                        font-size: 14px;
                    }
                    Text {
                        text: "热点会话";
                        color: #f8fafc;
                        font-size: 28px;
                        font-weight: 700;
                    }
                }

                Rectangle {
                    width: 88px;
                    height: 34px;
                    border-radius: 17px;
                    background: status == "稳定" ? #14532d : status == "注意" ? #854d0e : status == "风险" ? #7f1d1d : #334155;
                    Text {
                        text: status;
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 14px;
                        font-weight: 700;
                    }
                }
            }

            Text {
                text: status-reason;
                color: #cbd5e1;
                font-size: 14px;
                height: 40px;
                wrap: word-wrap;
                vertical-alignment: top;
            }

            HorizontalBox {
                spacing: 10px;
                height: 88px;
                MetricCard { label: "已运行"; value: elapsed; }
                MetricCard { label: "会话流量"; value: session-traffic; }
            }

            SectionCard {
                height: 156px;
                VerticalBox {
                    padding: 14px;
                    spacing: 12px;
                    Text { text: "实时速度"; color: #cbd5e1; font-size: 16px; font-weight: 700; }
                    HorizontalBox {
                        spacing: 10px;
                        height: 82px;
                        MetricCard { label: "下行"; value: down-speed; value-size: 22px; }
                        MetricCard { label: "上行"; value: up-speed; value-size: 22px; }
                    }
                }
            }

            HorizontalBox {
                spacing: 10px;
                height: 88px;
                MetricCard { label: "设备"; value: connected-count; value-size: 22px; }
                MetricCard { label: "电量"; value: battery; value-size: 22px; }
                MetricCard { label: "温度"; value: temperature; value-size: 22px; }
            }

            Text {
                text: last-updated;
                color: #94a3b8;
                font-size: 12px;
                height: 20px;
            }
        }
    }
}
